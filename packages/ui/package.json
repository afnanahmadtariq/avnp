{
  "name": "@relay/ui",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./classes": "./src/classes.ts",
    "./styles.css": "./src/styles.css",
    "./tokens": "./src/tokens.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@relay/eslint-config": "workspace:*",
    "@relay/typescript-config": "workspace:*",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
