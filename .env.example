# Active runtime configuration
# DATABASE_URL is the only value required for persisted product routes locally.
# The remaining active values have safe local defaults in the application.
NODE_ENV=development
RELAY_MODE=fixture
APP_VERSION=0.0.0
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
NUXT_PUBLIC_API_BASE=http://localhost:4000/api/v1
PROVIDER_TIMEOUT_MS=20000

# Active persistence
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay

# Reserved infrastructure configuration
# Docker Compose starts Redis, but Relay does not connect to it until the
# BullMQ worker implementation is added.
QUEUE_PROVIDER=memory
REDIS_URL=redis://localhost:6379

# Reserved provider configuration
# The variables below are not read by the current runtime. Adding credentials
# does not enable a provider until its adapter, webhook handling, and tests are
# implemented. See docs/development/service-setup.md before creating accounts.

# Voice agent and telephony
CALL_PROVIDER=fixture
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Structured reasoning and document extraction
AI_PROVIDER=fixture
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OCR_PROVIDER=mock

# Business discovery (Google primary; Yelp optional fallback)
DISCOVERY_PROVIDER=fixture
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=

# Authentication and private evidence storage
AUTH_PROVIDER=local
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=relay-evidence
