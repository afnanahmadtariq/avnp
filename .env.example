# Runtime
NODE_ENV=development
APP_VERSION=0.0.0
WEB_PORT=3000
API_HOST=0.0.0.0
API_PORT=4000
CORS_ORIGINS=http://localhost:3000
NUXT_PUBLIC_API_BASE=http://localhost:4000/api/v1

# Local infrastructure
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay
REDIS_URL=redis://localhost:6379

# Voice and telephony - required only for live calls
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI and document extraction - required only for provider-backed flows
OPENAI_API_KEY=
OCR_PROVIDER=mock

# Business discovery - optional in credential-free development
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=

# Authentication and storage - optional until their adapters are enabled
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
