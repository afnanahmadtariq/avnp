# Relay defaults to deterministic fixture mode. It needs PostgreSQL for persisted
# product routes, but fixture mode does not need paid provider credentials.
NODE_ENV=development
RELAY_MODE=fixture
APP_VERSION=0.0.0
API_HOST=0.0.0.0
API_PORT=4000
# Origin only. Relay appends /api/v1/webhooks/elevenlabs for call callbacks.
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
NUXT_PUBLIC_API_BASE=http://localhost:4000/api/v1
PROVIDER_TIMEOUT_MS=20000

# PostgreSQL 18.4 persistence
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay

# BullMQ orchestration. Use QUEUE_PROVIDER=redis in live mode.
QUEUE_PROVIDER=memory
REDIS_URL=redis://localhost:6379

# Voice interview, negotiation, and ElevenLabs native Twilio calling.
CALL_PROVIDER=fixture
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Optional dedicated intake interviewer; falls back to ELEVENLABS_AGENT_ID.
ELEVENLABS_INTERVIEW_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
# Optional in Relay. Add both only when active-call cancellation must terminate
# the underlying Twilio call immediately.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# OpenAI Responses for structured quote and document extraction.
AI_PROVIDER=fixture
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OCR_PROVIDER=mock

# Google Places API (New) business discovery.
DISCOVERY_PROVIDER=fixture
GOOGLE_PLACES_API_KEY=

# Clerk authentication. Only the publishable key is browser-safe.
AUTH_PROVIDER=local
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Private Supabase Storage for documents, transcripts, recordings, and
# extraction evidence. Keep the bucket private and the service-role key server-only.
STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=relay-evidence

# Full live composition: RELAY_MODE=live, QUEUE_PROVIDER=redis,
# AUTH_PROVIDER=clerk, DISCOVERY_PROVIDER=google, CALL_PROVIDER=elevenlabs,
# AI_PROVIDER=openai, OCR_PROVIDER=openai, STORAGE_PROVIDER=supabase.
# See docs/development/service-setup.md for exact account setup.
