{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.*"],
  "globalEnv": [
    "NODE_ENV",
    "RELAY_MODE",
    "APP_VERSION",
    "API_HOST",
    "API_PORT",
    "API_PUBLIC_URL",
    "CORS_ORIGINS",
    "NUXT_PUBLIC_API_BASE",
    "PROVIDER_TIMEOUT_MS",
    "DATABASE_URL",
    "QUEUE_PROVIDER",
    "REDIS_URL",
    "AUTH_PROVIDER",
    "NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "DISCOVERY_PROVIDER",
    "GOOGLE_PLACES_API_KEY",
    "CALL_PROVIDER",
    "ELEVENLABS_API_KEY",
    "ELEVENLABS_AGENT_ID",
    "ELEVENLABS_PHONE_NUMBER_ID",
    "ELEVENLABS_WEBHOOK_SECRET",
    "AI_PROVIDER",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "OCR_PROVIDER",
    "STORAGE_PROVIDER",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_STORAGE_BUCKET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".nuxt/**", ".output/**", "dist/**"]
    },
    "@relay/database#build": {
      "dependsOn": ["db:generate"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "@relay/database#typecheck": {
      "dependsOn": ["db:generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:validate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
