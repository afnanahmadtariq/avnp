{
  "name": "relay",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Relay AI voice negotiation platform monorepo",
  "engines": {
    "node": "24.x",
    "pnpm": "11.15.0"
  },
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "boundaries": "node scripts/check-boundaries.mjs",
    "build": "turbo run build",
    "check": "corepack pnpm format:check && corepack pnpm boundaries && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build",
    "clean": "turbo run clean",
    "dev": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev",
    "dev:api": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev --filter=@relay/api",
    "dev:web": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev --filter=@relay/web",
    "dev:worker": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev --filter=@relay/worker",
    "db:generate": "turbo run db:generate --filter=@relay/database",
    "db:push": "turbo run db:push --filter=@relay/database",
    "db:reset": "turbo run db:reset --filter=@relay/database",
    "db:seed": "turbo run db:seed --filter=@relay/database",
    "db:validate": "turbo run db:validate --filter=@relay/database",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "6.0.3"
  }
}
