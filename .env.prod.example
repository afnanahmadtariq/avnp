# Relay production runtime (API + worker on the VM).
# Fill an ignored local .env.prod, then store its complete contents in the
# protected GitHub PROD_ENV_FILE environment secret. Never commit real values.
NODE_ENV=production
RELAY_MODE=live
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=https://api.zerotools.online
CORS_ORIGINS=https://relay.zerotools.online
NUXT_PUBLIC_API_BASE=https://api.zerotools.online/api/v1
PROVIDER_TIMEOUT_MS=20000

# Managed PostgreSQL 18. Use the provider's TLS-required connection string.
DATABASE_URL=

# Managed Redis used by BullMQ. Prefer a TLS rediss:// connection string.
QUEUE_PROVIDER=redis
REDIS_URL=

# Clerk. The publishable key is also configured in Vercel at build time.
AUTH_PROVIDER=clerk
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Google Places API (New) business discovery.
DISCOVERY_PROVIDER=google
GOOGLE_PLACES_API_KEY=

# ElevenLabs Agents with its connected Twilio phone number.
CALL_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_INTERVIEW_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=

# Optional: only needed for immediate provider-side cancellation.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# OpenAI Responses structured extraction.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OCR_PROVIDER=openai

# Private Supabase Storage evidence bucket.
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=relay-evidence
