{
  "name": "@relay/api",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Versioned HTTP API for the Relay platform",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node --enable-source-maps dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clerk/backend": "3.11.7",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@relay/contracts": "workspace:*",
    "@relay/database": "workspace:*",
    "@relay/domain": "workspace:*",
    "@relay/integrations": "workspace:*",
    "@relay/queue": "workspace:*",
    "@relay/runtime-config": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@relay/eslint-config": "workspace:*",
    "@relay/typescript-config": "workspace:*",
    "@types/node": "24.13.3",
    "@types/supertest": "7.2.1",
    "eslint": "10.7.0",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "24.18.0"
  }
}
