# Version control and local tooling
.git
.github
.idea
.vscode
.DS_Store

# Dependencies and generated output are rebuilt inside the image
node_modules
**/node_modules
.pnpm-store
.turbo
**/.turbo
**/.nuxt
**/.output
**/dist
**/coverage
**/*.tsbuildinfo
packages/database/src/generated

# Secrets must never enter a Docker build context
.env
.env.*
**/.env
**/.env.*
*.pem

# Local-only data and logs
.data
tmp
**/*.log

# Product documentation and design sources are not runtime inputs
docs
assets
